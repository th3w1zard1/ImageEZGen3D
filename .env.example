# Optional Hugging Face token. Do not commit real secrets.
# Leave this blank unless you need gated models or Hub upload access.
HF_TOKEN=

# Config source and runtime knobs. pyproject.toml is the source of truth.
IMAGEEZ_CONFIG=pyproject.toml
# Local default: outputs/. On HF Spaces with persistent storage, the app uses /data/outputs when /data is writable.
IMAGEEZ_OUTPUT_DIR=outputs
IMAGEEZ_ADAPTER=auto
IMAGEEZ_CPU_ADAPTER=cpu-demo
IMAGEEZ_ZEROGPU_ADAPTER=hunyuan-zerogpu
IMAGEEZ_RUNTIME=auto
IMAGEEZ_PREFER_ZEROGPU=true
IMAGEEZ_FALLBACK_TO_CPU=true
IMAGEEZ_FORCE_CPU=false
IMAGEEZ_ZEROGPU_ENABLED=true
IMAGEEZ_ZEROGPU_SIZE=large

# Optional release and publication controls.
IMAGEEZ_RELEASE_OWNER=
IMAGEEZ_RELEASE_REPO=
IMAGEEZ_RELEASE_PRIMARY_BRANCH=main
IMAGEEZ_RELEASE_FALLBACK_BRANCHES=master
IMAGEEZ_RELEASE_PUBLISH_LATEST_BRANCHES=main,master
IMAGEEZ_RELEASE_DEFAULT_IMAGE_TAG=latest
IMAGEEZ_RELEASE_IMAGE_TAG=
IMAGEEZ_RELEASE_CREATE_MISSING_TARGETS=true
IMAGEEZ_RELEASE_GITLAB_ENABLED=true
IMAGEEZ_RELEASE_CODEBERG_ENABLED=true
IMAGEEZ_RELEASE_HF_ENABLED=true
IMAGEEZ_RELEASE_GHCR_ENABLED=true
IMAGEEZ_RELEASE_DOCKERHUB_ENABLED=false
IMAGEEZ_RELEASE_GITLAB_REGISTRY_ENABLED=false

# Optional external tokens. Leave blank unless the related target is enabled.
GITLAB_TOKEN=
GITLAB_USERNAME=
CODEBERG_TOKEN=
HF_TOKEN=
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=

# Local Gradio launch defaults.
IMAGEEZ_HOST=0.0.0.0
IMAGEEZ_PORT=7865
IMAGEEZ_SHARE=false
